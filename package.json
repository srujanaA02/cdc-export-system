{
  "name": "cdc-export-system",
  "version": "1.0.0",
  "scripts": {
    "start": "node src/index.js",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit --coverage --forceExit",
    "test:integration": "jest tests/integration --coverage --forceExit"
  },
  "jest": {
    "testMatch": ["**/tests/**/*.test.js"],
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
    }
  },
  "dependencies": {
    "csv-stringify": "^6.4.4",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  }
}
